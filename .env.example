# =============================================================================
# Aquila Guardian — environment configuration
# Copy this file to `.env` and fill in your own values. NEVER commit .env.
# =============================================================================

# Port the backend listens on (inside Docker or bare metal).
PORT=3000

# Admin password for the web configuration UI at / or /login.html
# Use something long and unique — this is the ONLY thing between the public
# internet and full control over your alerts. 32+ random characters recommended.
ADMIN_PASSWORD=change-me-to-a-long-random-string

# Public HTTPS URL where this backend is reachable from Twilio.
# Required for voice calls (Twilio needs to fetch /voice.mp3 from here).
# Example: https://alerts.mydomain.tld   (no trailing slash)
PUBLIC_HOST=

# Secret used to derive the AES-256-GCM key that encrypts contacts on disk.
# Generate once with: openssl rand -hex 32
# IF YOU CHANGE THIS AFTER FIRST RUN, previously encrypted contacts become
# unreadable. Keep it stable (or migrate your config.json manually).
WEBHOOK_SECRET=change-me-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# Telegram Bot — free, unlimited alerts
# Create a bot with @BotFather on Telegram and paste the token here.
# Your emergency contacts' chat IDs go in the web UI, not in .env.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Twilio — SMS and Voice alerts. REQUIRED for SMS/voice, optional if you
# only want Telegram. Sign up at https://www.twilio.com/console
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# The Twilio phone numbers that will send SMS / make voice calls on your behalf.
# Format: +15551234567 (E.164, no spaces or dashes).
# You can buy numbers in the Twilio console; one number can do both SMS and voice.
TWILIO_SMS_FROM=
TWILIO_VOICE_FROM=

# -----------------------------------------------------------------------------
# Rate limiting (optional)
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=120
